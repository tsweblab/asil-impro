---
import FadeInText from '@astroanimate/core/FadeInText';
import Layout from '../layouts/Layout.astro';
import ContactForm from '../components/ContactForm.astro';
import SitePhoto from '../components/SitePhoto.astro';
import SocialLinks from '../components/SocialLinks.astro';
import { getSettings } from '../lib/keystatic';
import scenePhoto from '../assets/scene-impro.jpg';

const settings = await getSettings();
---

<Layout
  title="Contact — ASIL Impro"
  description="Contactez l'ASIL Impro à Saint-Étienne : inscriptions aux ateliers et stages, réservations de spectacles, propositions de lieux. Formulaire, email et réseaux sociaux."
>
  <section class="container-site py-14 sm:py-20">
    <FadeInText duration={0.7}>
      <p class="eyebrow mb-4">On vous répond vite</p>
      <h1 class="section-title text-5xl sm:text-6xl">Contact</h1>
    </FadeInText>
    <p class="mt-5 max-w-2xl leading-relaxed text-white/75">
      Une question sur les ateliers, une réservation, une scène à nous proposer ?
      Écrivez-nous, on improvise une réponse rapidement.
    </p>
  </section>

  <section class="container-site grid gap-12 pb-20 lg:grid-cols-[minmax(0,1.15fr)_minmax(0,0.85fr)] lg:gap-16">
    <div>
      <h2 class="mb-7 text-2xl">Envoyez-nous un message</h2>
      <ContactForm />
    </div>

    <aside class="flex flex-col gap-8">
      <SitePhoto
        publique={settings.photoContact}
        fallback={scenePhoto}
        alt="Spectacle d'improvisation de l'ASIL"
        class="w-full rounded-2xl object-cover shadow-2xl shadow-black/60"
        widths={[480, 800, 1200]}
        sizes="(min-width: 1024px) 26rem, 100vw"
        loading="lazy"
      />

      <div class="card-scene p-8">
        <h2 class="text-2xl">Nos coordonnées</h2>
        <ul class="mt-5 grid gap-4 text-sm">
          <li>
            <span class="block font-sans text-[0.65rem] font-semibold uppercase tracking-[0.25em] text-white/50">Email</span>
            <a href={`mailto:${settings.email}`} class="font-semibold text-white transition-colors hover:text-asil-red">
              {settings.email}
            </a>
          </li>
          {settings.telephones.length > 0 && (
            <li>
              <span class="block font-sans text-[0.65rem] font-semibold uppercase tracking-[0.25em] text-white/50">Téléphone</span>
              <ul class="grid gap-1">
                {settings.telephones.map((t) => (
                  <li>
                    <a href={`tel:${t.numero.replace(/[\s.]/g, '')}`} class="font-semibold text-white transition-colors hover:text-asil-red">
                      {t.numero}
                    </a>
                    {t.libelle && <span class="text-white/60"> — {t.libelle}</span>}
                  </li>
                ))}
              </ul>
            </li>
          )}
          <li>
            <span class="block font-sans text-[0.65rem] font-semibold uppercase tracking-[0.25em] text-white/50">Ateliers</span>
            <p class="text-white/80">
              Amicale Laïque Michelet<br />
              26 rue Coraly-Royet, 42100 Saint-Étienne
            </p>
          </li>
          <li>
            <span class="mb-2 block font-sans text-[0.65rem] font-semibold uppercase tracking-[0.25em] text-white/50">Réseaux sociaux</span>
            <SocialLinks facebook={settings.facebook} instagram={settings.instagram} />
          </li>
        </ul>
      </div>
    </aside>
  </section>
</Layout>
