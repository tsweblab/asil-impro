---
import FadeInText from '@astroanimate/core/FadeInText';
import Layout from '../layouts/Layout.astro';
import StageCard from '../components/StageCard.astro';
import SitePhoto from '../components/SitePhoto.astro';
import { getStages, getSettings } from '../lib/keystatic';
import stagePhoto from '../assets/stage-nb.jpg';

const stages = await getStages();
const settings = await getSettings();
const today = new Date().toISOString().slice(0, 10);
const aVenir = stages.filter((s) => (s.dateFin ?? s.dateDebut ?? '') >= today);
---

<Layout
  title="Stages d'improvisation — ASIL Impro"
  description="Stages d'improvisation théâtrale d'une journée à Saint-Étienne, ouverts à toutes et tous. Thèmes variés, intervenantes expérimentées : découvrez les prochaines dates."
>
  <section class="container-site grid items-center gap-10 py-14 sm:py-20 lg:grid-cols-[minmax(0,1.2fr)_minmax(0,0.8fr)] lg:gap-16">
    <div>
      <FadeInText duration={0.7}>
        <p class="eyebrow mb-4">Une journée pour jouer</p>
        <h1 class="section-title text-5xl sm:text-6xl">Les stages</h1>
      </FadeInText>
      <blockquote class="mt-7 border-l-2 border-asil-red pl-6 font-display text-2xl italic text-white/90">
        « Toi-même tu sais… »
      </blockquote>
      <p class="mt-5 leading-relaxed text-white/80">
        L'ASIL propose des stages d'une journée <strong class="text-white">ouverts à toutes et à tous</strong>,
        chacun autour d'un thème particulier. Ils ont lieu de 10h à 17h, avec une
        pause d'une heure pour manger.
      </p>
      <p class="mt-4 leading-relaxed text-white/80">
        Prévoyez votre pique-nique et une tenue confortable !
      </p>
    </div>
    <SitePhoto
      publique={settings.photoStages}
      fallback={stagePhoto}
      alt="Participants d'un stage d'improvisation de l'ASIL"
      class="w-full rounded-2xl object-cover shadow-2xl shadow-black/60"
      widths={[480, 800, 1200]}
      sizes="(min-width: 1024px) 26rem, 100vw"
      loading="eager"
    />
  </section>

  <section class="container-site pb-20" aria-labelledby="stages-a-venir">
    <h2 id="stages-a-venir" class="section-title mb-12 text-4xl sm:text-5xl">Prochains stages</h2>

    {aVenir.length === 0 ? (
      <div class="card-scene p-10 text-center">
        <h3 class="text-2xl">Les prochaines dates arrivent bientôt</h3>
        <p class="mt-3 text-white/70">
          Le calendrier des stages de la saison est en préparation.
          <a href="/contact" class="font-semibold text-asil-red hover:underline">Contactez-nous</a>
          pour être prévenu·e en avant-première.
        </p>
      </div>
    ) : (
      <div class="grid gap-8">
        {aVenir.map((stage, i) => (
          <StageCard stage={stage} index={i} />
        ))}
      </div>
    )}
  </section>
</Layout>
