---
import FadeInText from '@astroanimate/core/FadeInText';
import Layout from '../layouts/Layout.astro';
import EventCard from '../components/EventCard.astro';
import { getEvenementsAVenir, grouperParMois } from '../lib/keystatic';

const evenements = await getEvenementsAVenir();
const parMois = grouperParMois(evenements);

// Ancre URL-safe pour un mois : "Février 2027" -> "fevrier-2027"
const ancre = (mois: string) =>
  mois
    .toLowerCase()
    .replace(/é/g, 'e')
    .replace(/û/g, 'u')
    .replace(/\s+/g, '-');
---

<Layout
  title="Programme des spectacles — ASIL Impro"
  description="L'agenda des spectacles d'improvisation de l'ASIL à Saint-Étienne : catch d'impro, cabarets, baptêmes de scène, gala… Toutes les dates, mois par mois."
>
  <section class="container-site py-14 sm:py-20">
    <FadeInText duration={0.7}>
      <h1 class="section-title text-4xl sm:text-5xl">Le programme</h1>
    </FadeInText>
    <p class="mt-5 max-w-2xl leading-relaxed text-white/75">
      Plus de 30 spectacles par saison à Saint-Étienne et dans sa région.
      Retrouvez toutes nos dates, mois par mois.
    </p>

    {parMois.size > 1 && (
      <nav aria-label="Aller à un mois" class="mt-8 flex flex-wrap gap-2">
        {[...parMois.keys()].map((mois) => (
          <a
            href={`#${ancre(mois)}`}
            class="rounded-full border border-white/25 px-4 py-1.5 font-display text-xs font-bold uppercase tracking-wide text-white/80 transition-all duration-300 hover:border-asil-red hover:bg-asil-red hover:text-white"
          >
            {mois}
          </a>
        ))}
      </nav>
    )}
  </section>

  <section class="container-site pb-20">
    {evenements.length === 0 && (
      <div class="rounded-lg border border-white/10 bg-asil-gray-dark p-10 text-center">
        <h2 class="text-2xl">La prochaine saison se prépare…</h2>
        <p class="mt-3 text-white/70">
          Les dates arrivent bientôt. Suivez-nous sur les réseaux pour ne rien manquer !
        </p>
      </div>
    )}

    <div class="grid gap-14">
      {[...parMois.entries()].map(([mois, liste]) => (
        <section id={ancre(mois)} aria-label={mois} class="scroll-mt-24">
          <div class="mb-6 flex items-center gap-5">
            <h2 class="shrink-0 text-2xl text-asil-red sm:text-3xl">{mois}</h2>
            <div class="h-0.5 grow rounded bg-white/10" aria-hidden="true"></div>
          </div>
          <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
            {liste.map((e) => (
              <EventCard evenement={e} />
            ))}
          </div>
        </section>
      ))}
    </div>
  </section>
</Layout>
