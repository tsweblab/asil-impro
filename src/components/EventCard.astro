---
import { formatDateLongue, formatHeure, type Evenement } from '../lib/keystatic';

interface Props {
  evenement: Evenement;
  /** Variante compacte pour le carrousel de l'accueil. */
  compact?: boolean;
}

const { evenement, compact = false } = Astro.props;
const heure = formatHeure(evenement.date!);
---

<article
  class:list={[
    'card-scene card-hover flex h-full flex-col gap-3 p-6',
    compact ? '' : 'sm:p-7',
  ]}
>
  <p class="font-sans text-[0.7rem] font-semibold uppercase tracking-[0.2em] text-asil-red">
    {formatDateLongue(evenement.date!)}{heure && ` — ${heure}`}
  </p>
  <!-- Séparateur « billet de spectacle » : pointillés + encoches perforées -->
  <div class="relative -mx-6 my-0.5 border-t border-dashed border-white/15" aria-hidden="true">
    <span class="absolute -left-2 top-1/2 size-4 -translate-y-1/2 rounded-full bg-asil-night"></span>
    <span class="absolute -right-2 top-1/2 size-4 -translate-y-1/2 rounded-full bg-asil-night"></span>
  </div>
  <h3 class="text-2xl text-white">{evenement.titre}</h3>
  <p class="text-sm font-semibold text-white/80">
    {evenement.lieu}
    {evenement.adresse && <span class="block font-normal text-white/50">{evenement.adresse}</span>}
  </p>
  {!compact && evenement.description && (
    <p class="text-sm leading-relaxed text-white/70">{evenement.description}</p>
  )}
  {evenement.lienReservation && (
    <a
      href={evenement.lienReservation}
      target="_blank"
      rel="noopener noreferrer"
      class="btn-red mt-auto self-start min-h-10 px-5 text-xs"
    >
      Réserver
    </a>
  )}
</article>
