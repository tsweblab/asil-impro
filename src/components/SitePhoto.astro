---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

/**
 * Photo remplaçable via Keystatic (« Paramètres du site ») :
 * si une image a été uploadée, on la sert telle quelle ; sinon on utilise
 * l'image par défaut du projet, optimisée par Astro (WebP + srcset).
 */
interface Props {
  publique?: string | null;
  fallback: ImageMetadata;
  alt: string;
  class?: string;
  widths?: number[];
  sizes?: string;
  loading?: 'eager' | 'lazy';
}

const {
  publique = null,
  fallback,
  alt,
  class: className,
  widths = [480, 800, 1200],
  sizes = '100vw',
  loading = 'lazy',
} = Astro.props;
---

{publique ? (
  <img src={publique} alt={alt} class={className} loading={loading} />
) : (
  <Image src={fallback} alt={alt} class={className} widths={widths} sizes={sizes} loading={loading} />
)}
