---
import SocialLinks from './SocialLinks.astro';
import type { Telephone } from '../lib/keystatic';

interface Props {
  facebook: string;
  instagram: string;
  email: string;
  telephones: Telephone[];
}

const { facebook, instagram, email, telephones } = Astro.props;
const annee = new Date().getFullYear();
---

<footer class="relative overflow-hidden border-t border-white/8 bg-asil-black">
  <div class="pointer-events-none absolute inset-0 [background:radial-gradient(45rem_22rem_at_50%_-40%,rgba(227,6,19,0.08),transparent_60%)]" aria-hidden="true"></div>
  <div class="container-site grid gap-10 py-14 md:grid-cols-3">
    <div>
      <img
        src="/images/logo-asil-blanc.png"
        alt="ASIL Impro"
        width="140"
        height="62"
        class="h-14 w-auto"
        loading="lazy"
      />
      <p class="mt-4 max-w-xs text-sm leading-relaxed text-white/60">
        Ateliers stéphanois d'improvisation loufoque — l'asso qui improvise à
        Saint-Étienne depuis 2002.
      </p>
    </div>

    <nav aria-label="Liens rapides" class="text-sm">
      <h2 class="mb-5 font-sans text-[0.68rem] font-semibold uppercase tracking-[0.28em] text-white/55">Liens rapides</h2>
      <ul class="grid gap-2 text-white/70">
        <li><a href="/" class="transition-colors hover:text-asil-red">Accueil</a></li>
        <li><a href="/programme" class="transition-colors hover:text-asil-red">Programme</a></li>
        <li><a href="/stages" class="transition-colors hover:text-asil-red">Stages</a></li>
        <li><a href="/ateliers" class="transition-colors hover:text-asil-red">Ateliers</a></li>
        <li><a href="/contact" class="transition-colors hover:text-asil-red">Contact</a></li>
        <li><a href="/mentions-legales" class="transition-colors hover:text-asil-red">Mentions légales</a></li>
      </ul>
    </nav>

    <div class="text-sm">
      <h2 class="mb-5 font-sans text-[0.68rem] font-semibold uppercase tracking-[0.28em] text-white/55">Gardons le contact !</h2>
      <ul class="grid gap-2 text-white/70">
        <li>
          <a href={`mailto:${email}`} class="font-semibold text-white transition-colors hover:text-asil-red">{email}</a>
        </li>
        {telephones.map((t) => (
          <li>
            <a href={`tel:${t.numero.replace(/[\s.]/g, '')}`} class="transition-colors hover:text-asil-red">{t.numero}</a>
            {t.libelle && <span class="text-white/45"> — {t.libelle}</span>}
          </li>
        ))}
      </ul>
      <SocialLinks facebook={facebook} instagram={instagram} class="mt-5" />
    </div>
  </div>

  <div class="border-t border-white/10">
    <div class="container-site flex flex-col items-center justify-between gap-2 py-5 text-xs text-white/50 sm:flex-row">
      <p>© {annee} ASIL Impro — Tous droits réservés.</p>
      <p>
        Site réalisé par
        <a
          href="https://tsweb.fr"
          target="_blank"
          rel="noopener noreferrer"
          class="font-semibold text-white/80 transition-colors hover:text-asil-red"
        >
          TS WEB Lab
        </a>
      </p>
    </div>
  </div>
</footer>
