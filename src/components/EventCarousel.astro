---
import EventCard from './EventCard.astro';
import type { Evenement } from '../lib/keystatic';

interface Props {
  evenements: Evenement[];
}

const { evenements } = Astro.props;
---

<div class="relative" data-carousel>
  <ul class="carousel-track list-none p-0" role="list">
    {evenements.map((e) => (
      <li class="flex">
        <EventCard evenement={e} compact />
      </li>
    ))}
  </ul>

  {evenements.length > 1 && (
    <div class="mt-5 flex justify-end gap-3">
      <button
        type="button"
        data-carousel-prev
        aria-label="Événements précédents"
        class="grid size-11 place-items-center rounded-full border-2 border-white/40 text-white transition-all duration-300 hover:border-asil-red hover:bg-asil-red"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="size-5" aria-hidden="true">
          <path d="M15 6l-6 6 6 6" />
        </svg>
      </button>
      <button
        type="button"
        data-carousel-next
        aria-label="Événements suivants"
        class="grid size-11 place-items-center rounded-full border-2 border-white/40 text-white transition-all duration-300 hover:border-asil-red hover:bg-asil-red"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="size-5" aria-hidden="true">
          <path d="M9 6l6 6-6 6" />
        </svg>
      </button>
    </div>
  )}
</div>

<script>
  function initCarousels() {
    document.querySelectorAll<HTMLElement>('[data-carousel]').forEach((carousel) => {
      if (carousel.dataset.bound) return;
      carousel.dataset.bound = 'true';

      const track = carousel.querySelector<HTMLElement>('.carousel-track');
      if (!track) return;
      const pas = () => (track.firstElementChild?.clientWidth ?? 320) + 20;

      carousel
        .querySelector('[data-carousel-prev]')
        ?.addEventListener('click', () => track.scrollBy({ left: -pas(), behavior: 'smooth' }));
      carousel
        .querySelector('[data-carousel-next]')
        ?.addEventListener('click', () => track.scrollBy({ left: pas(), behavior: 'smooth' }));
    });
  }

  initCarousels();
  document.addEventListener('astro:page-load', initCarousels);
</script>
