---
import ScaleIn from '@astroanimate/core/ScaleIn';
import { formatDateLongue, type Stage } from '../lib/keystatic';

interface Props {
  stage: Stage;
  index?: number;
}

const { stage, index = 0 } = Astro.props;

const periode = stage.dateFin
  ? `Du ${formatDateLongue(stage.dateDebut!).toLowerCase()} au ${formatDateLongue(stage.dateFin).toLowerCase()}`
  : formatDateLongue(stage.dateDebut!);
---

<ScaleIn enhance={true} delay={index * 120} class="h-full">
  <article class="card-hover grid h-full gap-6 overflow-hidden rounded-lg border border-white/10 bg-asil-gray-dark md:grid-cols-[minmax(0,2fr)_minmax(0,3fr)]">
    {stage.image ? (
      <img
        src={stage.image}
        alt={`Stage : ${stage.titre}`}
        class="h-full min-h-48 w-full object-cover"
        loading="lazy"
      />
    ) : (
      <div class="grid min-h-48 place-items-center bg-gradient-to-br from-asil-red to-asil-red-dark" aria-hidden="true">
        <span class="font-display text-6xl font-black text-white/80">ASIL</span>
      </div>
    )}
    <div class="flex flex-col gap-3 p-6 md:py-8 md:pr-8 md:pl-0">
      <p class="font-display text-sm font-bold uppercase tracking-wide text-asil-red">{periode}</p>
      <h3 class="text-2xl text-white">{stage.titre}</h3>
      <ul class="grid gap-1.5 text-sm text-white/75">
        {stage.horaires && <li><strong class="text-white">Horaires :</strong> {stage.horaires}</li>}
        {stage.lieu && <li><strong class="text-white">Lieu :</strong> {stage.lieu}</li>}
        {stage.intervenant && <li><strong class="text-white">Intervenant·e :</strong> {stage.intervenant}</li>}
        {stage.tarif && <li><strong class="text-white">Tarif :</strong> {stage.tarif}</li>}
      </ul>
      {stage.description && <p class="text-sm leading-relaxed text-white/70">{stage.description}</p>}
      {stage.lienInscription && (
        <a
          href={stage.lienInscription}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-red mt-auto self-start"
        >
          S'inscrire
        </a>
      )}
    </div>
  </article>
</ScaleIn>
