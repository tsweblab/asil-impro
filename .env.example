# Clé API Resend (https://resend.com) pour l'envoi des emails du formulaire de contact.
# Sans cette clé, le formulaire fonctionne en mode "dev" : le message est loggé côté serveur.
RESEND_API_KEY=

# Adresse qui reçoit les messages du formulaire de contact
CONTACT_TO_EMAIL=admin@asil-impro.fr

# Expéditeur (domaine vérifié dans Resend)
CONTACT_FROM_EMAIL=contact@asil-impro.fr
